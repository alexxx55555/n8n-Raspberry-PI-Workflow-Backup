        "text": "=👤 *AD User Information*\n━━━━━━━━━━━━━━━━━━━━━━\n🆔 *Username:* `{{ $json.data.username }}`\n🔢 *Employee ID:* {{ $json.data.employeeNumber || 'N/A' }}\n📛 *Full Name:* {{ $json.data.fullName }}\n📧 *Email:* {{ $json.data.email }}\n📝 *Description:* {{ $json.data.description || 'N/A' }}\n💼 *Title:* {{ $json.data.title }}\n📞 *Phone:* {{ $json.data.telephoneNumber || 'N/A' }}\n👔 *Manager:* {{ $json.data.manager }}\n⚙️ *Account Enabled:* {{ $json.data.enabled ? '✅ Yes' : '❌ No' }}\n🔐 *Account Locked:* {{ $json.data.locked ? '🔒 Yes (Locked)' : '🔓 No' }}\n🕒 *Last Logon:* {{ $json.data.lastLogon }}\n🔑 *Password Last Set:* {{ $json.data.passwordLastSet }}\n📅 *Account Created:* {{ $json.data.accountCreatedDate }}\n━━━━━━━━━━━━━━━━━━━━━━\n📁 *Group Memberships*\n\n✉️ *Distribution Groups:*\n{{ $json.data.groups.distribution.length > 0 ? $json.data.groups.distribution.map(g => `• ${g}`).join('\\n') : '• None' }}\n\n🛡️ *Security Groups:*\n{{ $json.data.groups.security.length > 0 ? $json.data.groups.security.map(g => `• ${g}`).join('\\n') : '• None' }}\n━━━━━━━━━━━━━━━━━━━━━━\n🔎 *Requested by:* @{{ $('Parse Username').item.json.requested_by }}",
