    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.stdout?.trim();\n\nif (!raw || raw === '' || raw === '[]') {\n  return [{ json: { noChanges: true } }];\n}\n\ntry {\n  const parsed = JSON.parse(raw);\n  \n  // Single object\n  if (!Array.isArray(parsed)) {\n    return [{ json: parsed }];\n  }\n  \n  // Empty array\n  if (parsed.length === 0) {\n    return [{ json: { noChanges: true } }];\n  }\n  \n  // Array of events\n  return parsed.map(e => ({ json: e }));\n} catch (e) {\n  return [{ json: { noChanges: true } }];\n}"
