    },
    {
      "parameters": {
        "jsCode": "const DAYS = 7;\nconst cutoff = Date.now() - DAYS * 86400000;\nconst items = $input.first().json?.data?.boards?.[0]?.groups?.[0]?.items_page?.items || [];\nconst toArchive = [];\nfor (const item of items) {\n  const updated = new Date(item.updated_at).getTime();\n  if (!isNaN(updated) && updated < cutoff) {\n    toArchive.push({ json: { itemId: item.id, itemName: item.name, daysOld: Math.floor((Date.now() - updated) / 86400000) } });\n  }\n}\nreturn toArchive;"
      },
