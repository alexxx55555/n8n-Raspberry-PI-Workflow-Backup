      "name": "Every Minute",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -240,
        -304
      ]
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst israelTime = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Jerusalem' }));\nconst dayOfWeek = israelTime.getDay();\nconst hour = israelTime.getHours();\nconst minute = israelTime.getMinutes();\nconst dayName = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][dayOfWeek];\n\nconst scheduledMessages = [\n  {\n    id: 'daily-good-morning',\n    channel: 'C08BDV59Q6M',\n    text: '🌅 Good morning everyone! Have an amazing day! ✨',\n    hour: 8,\n    minute: 0,\n    days: ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'],\n    enabled: true\n  }\n];\n\nconst toSend = scheduledMessages.filter(msg => {\n  if (!msg.enabled) return false;\n  if (msg.hour !== hour || msg.minute !== minute) return false;\n  if (!msg.days.includes(dayName)) return false;\n  if (msg.monthDay && israelTime.getDate() !== msg.monthDay) return false;\n  return true;\n});\n\nif (toSend.length === 0) {\n  return [];\n}\n\nreturn toSend.map(msg => ({ json: { channel: msg.channel, text: msg.text, id: msg.id } }));"
      },
      "id": "6b13842a-0cf3-49fa-a6ad-8903b761ca57",
      "name": "Check Schedule",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
