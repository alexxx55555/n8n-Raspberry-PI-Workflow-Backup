              "value2": "success"
            }
          ]
        }
      },
      "id": "33af7e9d-ce83-4f68-8776-20cd90f97a30",
      "name": "User Found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1136,
        704
      ]
    },
    {
      "parameters": {
        "jsCode": "const u = $json.data;\nconst distGroups = u.groups?.distribution?.length > 0 ? u.groups.distribution.map(g => `• ${g}`).join('\\n') : '• None';\nconst secGroups = u.groups?.security?.length > 0 ? u.groups.security.map(g => `• ${g}`).join('\\n') : '• None';\n\nconst text = `👤 *AD User: ${u.username}*\n━━━━━━━━━━━━━━━━━━\n📛 Name: ${u.fullName}\n📧 Email: ${u.email}\n💼 Title: ${u.title || 'N/A'}\n📞 Phone: ${u.telephoneNumber || 'N/A'}\n👔 Manager: ${u.manager || 'N/A'}\n✅ Enabled: ${u.enabled ? 'Yes' : 'No'}\n🔒 Locked: ${u.locked ? 'Yes' : 'No'}\n🕒 Last Logon: ${u.lastLogon}\n🔑 Pwd Last Set: ${u.passwordLastSet}\n━━━━━━━━━━━━━━━━━━\n🛡️ Security Groups:\n${secGroups}\n📨 Distribution Groups:\n${distGroups}`;\n\nreturn [{ json: { text, chatId: $json.chatId } }];"
      },
      "id": "74ba6cc5-6998-4516-a89e-52adeb8ceee1",
      "name": "Format User Info",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        496
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { text: `❌ User not found: ${$('Parse Command').first().json.username}`, chatId: $json.chatId } }];"
      },
