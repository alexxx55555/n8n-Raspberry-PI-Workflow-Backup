    {
      "parameters": {
        "jsCode": "const item = $json;\n\nif (item.error || !item.stdout || item.stdout.trim() === '') {\n  return [{ json: { status: 'error', message: item.stderr || 'No output from AD script.', chatId: $('Parse Command').first().json.chatId } }];\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(item.stdout);\n} catch(e) {\n  const match = item.stdout.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    try { parsed = JSON.parse(match[0]); } catch(e2) {\n      return [{ json: { status: 'error', message: 'Failed to parse AD response.', chatId: $('Parse Command').first().json.chatId } }];\n    }\n  } else {\n    return [{ json: { status: 'error', message: 'Unexpected response from AD.', chatId: $('Parse Command').first().json.chatId } }];\n  }\n}\n\nparsed.chatId = $('Parse Command').first().json.chatId;\nreturn [{ json: parsed }];"
      },
      "id": "9f4efbad-fe70-4643-be43-1f5b9ebb2703",
      "name": "Parse AD Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        704
      ]
    },
    {
      "parameters": {
        "conditions": {
