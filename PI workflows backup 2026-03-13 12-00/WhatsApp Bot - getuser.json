      "position": [
        -192,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body.payload.body.trim();\nconst chatId = $json.body.payload.from;\nconst parts = body.split(/\\s+/);\nconst cmd = parts[0].toLowerCase();\nconst arg = parts[1] || '';\n\nconst username = arg.replace(/[^a-zA-Z0-9._-]/g, '');\n\nif (cmd === '!getuser') {\n  if (!username || username.length === 0) {\n    return [{ json: { cmd, username: '', chatId, error: true, message: '❌ Usage: !getuser <username>' } }];\n  }\n  if (username.length > 64) {\n    return [{ json: { cmd, username: '', chatId, error: true, message: '❌ Username too long (max 64 chars).' } }];\n  }\n  return [{ json: { cmd, username, chatId, error: false, message: '' } }];\n}\n\nreturn [{ json: { cmd, username: '', chatId, error: true, message: '❓ Unknown command. Available: !getuser <username>' } }];"
      },
      "id": "002e5cd3-6cc0-4a0d-8bae-f22aecf7d3aa",
