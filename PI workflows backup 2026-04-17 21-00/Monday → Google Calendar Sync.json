      "parameters": {
        "jsCode": "// Merge all 3 branches and update static map\nconst staticData = $getWorkflowStaticData('global');\nstaticData.eventMap = staticData.eventMap || {};\nconst all = $input.all();\nfor (const row of all) {\n  const j = row.json;\n  if (j.op === 'create' && j.id) { staticData.eventMap[j.itemId] = { eventId: j.id, due: j.dueDate, updated_at: new Date().toISOString() }; }\n  if (j.op === 'update' && j.id) { staticData.eventMap[j.itemId] = { eventId: j.id, due: j.dueDate, updated_at: new Date().toISOString() }; }\n  if (j.op === 'delete') { delete staticData.eventMap[j.itemId]; }\n}\nreturn [{ json: { processed: all.length } }];"
      },
