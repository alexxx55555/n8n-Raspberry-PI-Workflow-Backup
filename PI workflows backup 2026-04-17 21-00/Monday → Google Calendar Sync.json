    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.eventMap = staticData.eventMap || {}; // itemId -> { eventId, due, updated_at }\nconst items = $input.first().json?.data?.boards?.[0]?.items_page?.items || [];\nconst toCreate = [];\nconst toUpdate = [];\nconst toDelete = [];\nconst seen = new Set();\nfor (const item of items) {\n  seen.add(item.id);\n  const status = (item.column_values || []).find(c => c.id === 'project_status');\n  const due = (item.column_values || []).find(c => c.id === 'date');\n  const dueStr = due?.text?.split(' ')[0] || '';\n  const prev = staticData.eventMap[item.id];\n  const shouldHaveEvent = dueStr && status?.text !== 'Done';\n  if (shouldHaveEvent && !prev) {\n    toCreate.push({ json: { itemId: item.id, itemName: item.name, dueDate: dueStr, url: `https://alex-it.monday.com/boards/5093821351/pulses/${item.id}` } });\n  } else if (shouldHaveEvent && prev && (prev.due !== dueStr || prev.updated_at !== item.updated_at)) {\n    toUpdate.push({ json: { itemId: item.id, itemName: item.name, dueDate: dueStr, eventId: prev.eventId, url: `https://alex-it.monday.com/boards/5093821351/pulses/${item.id}` } });\n  } else if (!shouldHaveEvent && prev) {\n    toDelete.push({ json: { itemId: item.id, eventId: prev.eventId } });\n  }\n}\n// Clean up stale entries for deleted items\nfor (const id in staticData.eventMap) {\n  if (!seen.has(id)) {\n    toDelete.push({ json: { itemId: id, eventId: staticData.eventMap[id].eventId } });\n  }\n}\nreturn [...toCreate.map(x => ({ json: { ...x.json, op: 'create' } })), ...toUpdate.map(x => ({ json: { ...x.json, op: 'update' } })), ...toDelete.map(x => ({ json: { ...x.json, op: 'delete' } }))];"
      },
