    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  \n  let serviceName = 'Unknown';\n  let apiUrl = '';\n  try {\n    serviceName = $('Extract Name & URL').all()[i].json.service_name || 'Unknown';\n    apiUrl = $('Extract Name & URL').all()[i].json.api_url || '';\n  } catch(e) {}\n  \n  // Derive status page URL from API URL\n  let statusPageUrl = '';\n  try {\n    const u = new URL(apiUrl);\n    statusPageUrl = u.origin;\n  } catch(e) {}\n  \n  const body = item.json.body || item.json;\n  \n  let indicator = 'unknown';\n  let description = 'Could not parse status';\n  \n  if (body && body.page && body.status && body.status.indicator) {\n    indicator = body.status.indicator;\n    description = body.status.description || '';\n    if (body.page.url) statusPageUrl = body.page.url;\n  }\n  else if (body && body.status && typeof body.status === 'object' && body.status.indicator) {\n    indicator = body.status.indicator;\n    description = body.status.description || '';\n  }\n  else if (body && body.status !== undefined && typeof body.status === 'string') {\n    const s = body.status.toLowerCase();\n    indicator = (s === 'ok' || s === 'active') ? 'none' : s;\n    description = (s === 'ok' || s === 'active') ? 'All Systems Operational' : body.status;\n  }\n  else if (typeof body === 'string') {\n    try {\n      const parsed = JSON.parse(body);\n      if (parsed.status && typeof parsed.status === 'object' && parsed.status.indicator) {\n        indicator = parsed.status.indicator;\n        description = parsed.status.description || '';\n        if (parsed.page && parsed.page.url) statusPageUrl = parsed.page.url;\n      }\n    } catch(e) {}\n  }\n  \n  const isHealthy = indicator === 'none';\n  \n  results.push({\n    json: {\n      service_name: serviceName,\n      indicator: indicator,\n      description: description,\n      is_healthy: isHealthy,\n      status_page_url: statusPageUrl,\n      checked_at: new Date().toLocaleString('en-GB', { \n        day: '2-digit', month: '2-digit', year: 'numeric',\n        hour: '2-digit', minute: '2-digit', hour12: false \n      })\n    }\n  });\n}\n\nreturn results;"
      },
