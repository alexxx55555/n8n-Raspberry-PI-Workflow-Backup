    {
      "parameters": {
        "jsCode": "// Detect /guest-invite slash command or bot DM\n// Expected format: /guest-invite email@example.com #channel-name 30d\n// Or in bot DM: guest invite email@example.com #channel-name 30d\nconst body = $input.first().json.body;\nconst event = body.event || {};\nconst text = (event.text || body.text || '').trim();\nconst sender = event.user || body.user_id || '';\nconst channel = event.channel || body.channel_id || '';\n\n// Parse: email, target channel, optional expiry\nconst parts = text.replace(/^\\/?guest[- ]?invite\\s*/i, '').split(/\\s+/);\nconst email = parts[0] || '';\nconst targetChannel = (parts[1] || '').replace(/[<#>]/g, '').split('|')[0]; // handle <#C123|channel-name>\nconst expiry = parts[2] || '30d'; // default 30 days\n\nif (!email || !email.includes('@')) {\n  return [{ json: { error: true, channel, message: ':x: Usage: `guest invite email@example.com #channel 30d`' } }];\n}\n\n// Calculate expiry timestamp\nconst daysMatch = expiry.match(/(\\d+)d/i);\nconst days = daysMatch ? parseInt(daysMatch[1]) : 30;\nconst expiryDate = new Date(Date.now() + days * 86400000).toISOString().split('T')[0];\n\nreturn [{\n  json: {\n    error: false,\n    email,\n    targetChannel,\n    sender,\n    channel,\n    days,\n    expiryDate\n  }\n}];"
      },
      "id": "beb751fd-95c5-4f90-bd3e-f998462bde16",
      "name": "Parse Guest Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        128
      ]
    },
    {
