    {
      "parameters": {
        "url": "https://slack.com/api/admin.users.invite",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.slackApi.accessToken }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"email\": \"{{ $json.email }}\",\n  \"channel_ids\": \"{{ $json.targetChannel }}\",\n  \"is_restricted\": true,\n  \"team_id\": \"REPLACE_TEAM_ID\"\n}",
        "options": {}
      },
      "id": "04c080f6-64cc-4dfd-8c5e-fd7982c6f243",
      "name": "Invite Guest (API)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        736,
        32
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst prevData = $('Parse Guest Command').first().json;\n\n// Log guest for tracking & expiry management\nconst logEntry = {\n  email: prevData.email,\n  channel: prevData.targetChannel,\n  invitedBy: prevData.sender,\n  expiryDate: prevData.expiryDate,\n  days: prevData.days,\n  invitedAt: new Date().toISOString(),\n  apiOk: input.ok || false,\n  apiError: input.error || null\n};\n\nconst success = input.ok === true;\n\nreturn [{\n  json: {\n    ...logEntry,\n    success,\n    notifyChannel: prevData.channel,\n    message: success\n      ? `:white_check_mark: Guest invite sent to *${prevData.email}* for <#${prevData.targetChannel}>\\nExpires: ${prevData.expiryDate} (${prevData.days} days)\\nInvited by: <@${prevData.sender}>`\n      : `:x: Failed to invite ${prevData.email}: ${input.error || 'Unknown error'}\\n_Note: Guest invites require a paid Slack plan. On free plan, this logs the request for manual processing._`\n  }\n}];"
      },
      "id": "052bff54-df23-441c-b50c-ddad1f5db32b",
