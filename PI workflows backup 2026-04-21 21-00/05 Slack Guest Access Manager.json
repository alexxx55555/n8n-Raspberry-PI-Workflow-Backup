    {
      "parameters": {
        "jsCode": "// Check static data for expired guests\nconst staticData = $getWorkflowStaticData('global');\nconst guests = staticData.guests || [];\nconst today = new Date().toISOString().split('T')[0];\nconst expired = guests.filter(g => g.expiryDate <= today);\nconst active = guests.filter(g => g.expiryDate > today);\n\n// Update static data to remove expired\nstaticData.guests = active;\n\nif (expired.length === 0) return [];\n\nreturn expired.map(g => ({\n  json: {\n    ...g,\n    message: `:hourglass_flowing_sand: Guest access expired: *${g.email}* in <#${g.channel}>\\nExpired: ${g.expiryDate}\\n_Please remove this guest manually or via Slack admin._`\n  }\n}));"
      },
