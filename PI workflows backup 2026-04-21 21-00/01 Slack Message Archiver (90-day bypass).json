            }
          }
        }
      },
      "id": "51facbf2-0259-4a59-831e-58579a5609e9",
      "name": "Fetch Channel History",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -352,
        -48
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nlet totalMessages = 0;\nlet channelsWithMessages = 0;\nconst today = new Date().toISOString().split('T')[0];\n\nfor (const item of items) {\n  const channelName = item.json.channelName || 'unknown';\n  const channelId = item.json.channelId || 'unknown';\n  const messages = item.json.messages || [];\n  \n  if (messages.length === 0) continue;\n  \n  channelsWithMessages++;\n  totalMessages += messages.length;\n  \n  // Build archive content as JSONL (one JSON object per line)\n  const archiveLines = messages.map(msg => JSON.stringify({\n    ts: msg.ts,\n    user: msg.user || msg.bot_id || 'unknown',\n    text: msg.text || '',\n    type: msg.type || 'message',\n    subtype: msg.subtype || null,\n    thread_ts: msg.thread_ts || null,\n    reactions: msg.reactions || [],\n    files: (msg.files || []).map(f => ({ name: f.name, url: f.url_private, mimetype: f.mimetype }))\n  }));\n  \n  const fileContent = archiveLines.join('\\n');\n  const fileName = `${channelName}_${today}.jsonl`;\n  const folderPath = `Slack-Archive/${channelName}`;\n  \n  results.push({\n    json: {\n      channelName,\n      channelId,\n      fileName,\n      folderPath,\n      messageCount: messages.length,\n      date: today\n    },\n    binary: {\n      data: {\n        data: Buffer.from(fileContent, 'utf-8').toString('base64'),\n        mimeType: 'application/jsonl',\n        fileName\n      }\n    }\n  });\n}\n\n// Add summary item at end\nif (results.length > 0) {\n  results.push({\n    json: {\n      _isSummary: true,\n      totalMessages,\n      channelsWithMessages,\n      date: today\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { _isSummary: true, totalMessages: 0, channelsWithMessages: 0, date: today } }];"
      },
