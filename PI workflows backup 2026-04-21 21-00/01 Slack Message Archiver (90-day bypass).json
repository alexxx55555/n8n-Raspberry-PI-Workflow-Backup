        -832,
        -48
      ]
    },
    {
      "parameters": {
        "jsCode": "// For each channel, fetch messages from last 24h\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const channelId = item.json.id;\n  const channelName = item.json.name;\n  \n  // 24 hours ago in Unix timestamp\n  const oldest = Math.floor((Date.now() - 86400000) / 1000).toString();\n  const latest = Math.floor(Date.now() / 1000).toString();\n  \n  results.push({\n    json: {\n      channelId,\n      channelName,\n      oldest,\n      latest\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "5df02cbf-833e-471b-bc66-3a990b5a3fb1",
      "name": "Prepare Fetch Params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -592,
        -48
      ]
    },
    {
      "parameters": {
        "url": "=https://slack.com/api/conversations.history",
        "sendQuery": true,
        "queryParameters": {
