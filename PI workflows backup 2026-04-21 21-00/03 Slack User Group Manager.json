    {
      "parameters": {
        "jsCode": "// Extract group mention from message text\n// Supports: @team-israel, @team-uk, @team-poland, @team-all, or any custom group\nconst body = $input.first().json.body;\nconst event = body.event || {};\nconst text = event.text || '';\nconst channel = event.channel || '';\nconst sender = event.user || '';\nconst botId = event.bot_id || '';\n\n// Skip bot messages\nif (botId) return [];\n\n// Find @group-name patterns\nconst groupPattern = /@(team-[a-z]+|group-[a-z]+|notify-[a-z]+)/gi;\nconst matches = text.match(groupPattern);\n\nif (!matches || matches.length === 0) return [];\n\nconst groups = matches.map(m => m.replace('@', '').toLowerCase());\n\nreturn groups.map(group => ({\n  json: { group, channel, sender, originalText: text }\n}));"
      },
      "id": "9f2aac53-239b-4f8b-b252-075586652953",
      "name": "Extract Group Mention",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        288
      ]
    },
    {
      "parameters": {
        "jsCode": "// User group definitions\n// Edit these to manage your groups — or switch to Google Sheets for dynamic management\nconst GROUP_MEMBERS = {\n  'team-israel': [\n    // Add Slack user IDs for Israel team\n    // 'U0123456789',\n  ],\n  'team-uk': [\n    // Add Slack user IDs for UK team\n  ],\n  'team-poland': [\n    // Add Slack user IDs for Poland team\n  ],\n  'team-all': [\n    // Populated dynamically: all members from all groups above\n  ]\n};\n\n// Auto-populate team-all\nGROUP_MEMBERS['team-all'] = [\n  ...new Set([\n    ...GROUP_MEMBERS['team-israel'],\n    ...GROUP_MEMBERS['team-uk'],\n    ...GROUP_MEMBERS['team-poland']\n  ])\n];\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const group = item.json.group;\n  const members = GROUP_MEMBERS[group];\n  \n  if (!members || members.length === 0) {\n    results.push({\n      json: {\n        ...item.json,\n        error: true,\n        message: `Unknown group: @${group}. Available groups: ${Object.keys(GROUP_MEMBERS).join(', ')}`\n      }\n    });\n    continue;\n  }\n  \n  // Build mention string\n  const mentions = members.map(uid => `<@${uid}>`).join(' ');\n  \n  results.push({\n    json: {\n      ...item.json,\n      error: false,\n      members: members,\n      memberCount: members.length,\n      mentionText: `:mega: *@${group}* (${members.length} members)\\n${mentions}\\n\\n> _Triggered by <@${item.json.sender}> in <#${item.json.channel}>_`\n    }\n  });\n}\n\nreturn results;"
      },
